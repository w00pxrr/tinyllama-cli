{
  "name": "tinyllama-gui",
  "version": "1.0.0",
  "description": "TinyLlama GUI - A modern chat interface for local language models",
  "main": "src/main/main.js",
  "author": "",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run dev:main\"",
    "dev:main": "electron .",
    "build": "npm run build:renderer",
    "build:renderer": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder --mac",
    "dist:dir": "npm run build && electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.tinyllama.gui",
    "productName": "TinyLlama GUI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "tinyllama_gui_backend.py"
    ],
    "extraResources": [
      {
        "from": "../tinyllama_gui_backend.py",
        "to": "tinyllama_gui_backend.py"
      }
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-toggle": "^1.0.3",
    "electron-log": "^4.4.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
