{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 300
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "env": {
    "MODEL_ID": "TinyLlama/TinyLlama-1.1B-Chat-v1.0",
    "MODEL_CACHE_DIR": "/tmp/models"
  }
}