{
  "name": "tinyllama",
  "version": "0.1.0",
  "description": "TinyLlama AI - Optimized for Next.js",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/components/ChatBox.d.ts",
      "import": "./dist/components/ChatBox.js"
    },
    "./server": {
      "types": "./dist/server/api.d.ts",
      "import": "./dist/server/api.js"
    },
    "./api-client": {
      "types": "./dist/api-client.d.ts",
      "import": "./dist/api-client.js"
    }
  },
  "bin": {
    "tinyllama": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js"
  },
  "keywords": ["ai", "llm", "tinyllama", "nextjs", "react"],
  "author": "Parker Solomon",
  "license": "Apache-2.0",
  "dependencies": {
    "@xenova/transformers": "^2.17.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "next": ">=14.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}